PORT=7888
HOST=localhost
# Per-request logging verbosity. One of:
#   none  → silent (no per-request log lines)
#   info  → one line per request with method, path, status, durationMs,
#           model, requestId, usage tokens (default)
#   body  → "info" plus full request body and assembled response body; use
#           this to audit exactly what was sent and received
LOGGING=info
# Output shape for log records. One of:
#   text  → human-readable single line — best for local development (default)
#   json  → single-line JSON per record — best for jq / Loki / Vector
LOG_FORMAT=text
# Comma- or whitespace-separated list of base model IDs (or CLI short names
# like opus4.6) whose effort-suffixed variants should be hidden from
# /v1/models and skipped when rewriting `reasoning_effort` to a suffixed
# backend ID. Use this for models the CLI advertises effort levels for but
# the backend currently 404s on (observed: claude-opus-4-6).
AUGMENT_DISABLE_EFFORT_MODELS=claude-opus-4-6
# Upstream HTTP timeouts (milliseconds). Node's global fetch defaults to a
# 5-minute headers timeout, which trips long thinking calls with
# UND_ERR_HEADERS_TIMEOUT. The proxy installs a global undici dispatcher with
# the values below. Set to 0 to disable a timeout entirely.
#   AUGMENT_HEADERS_TIMEOUT_MS — wait for first response byte (default 1800000 = 30 min)
#   AUGMENT_BODY_TIMEOUT_MS    — wait between body chunks    (default 1800000 = 30 min)
#   AUGMENT_CONNECT_TIMEOUT_MS — TCP connect                 (default 30000   = 30 s)
# AUGMENT_HEADERS_TIMEOUT_MS=1800000
# AUGMENT_BODY_TIMEOUT_MS=1800000
# AUGMENT_CONNECT_TIMEOUT_MS=30000
# AUGMENT_API_TOKEN=YOUR-ACCESS-TOKEN
# AUGMENT_API_URL=https://YOUR-TENANT.api.augmentcode.com
