PORT=7888
HOST=localhost
# Comma- or whitespace-separated list of base model IDs (or CLI short names
# like opus4.6) whose effort-suffixed variants should be hidden from
# /v1/models and skipped when rewriting `reasoning_effort` to a suffixed
# backend ID. Use this for models the CLI advertises effort levels for but
# the backend currently 404s on (observed: claude-opus-4-6).
AUGMENT_DISABLE_EFFORT_MODELS=claude-opus-4-6
# AUGMENT_API_TOKEN=YOUR-ACCESS-TOKEN
# AUGMENT_API_URL=https://YOUR-TENANT.api.augmentcode.com
